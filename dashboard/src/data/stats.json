  },
  {
   "step": 2,
   "title": "Usable sale prices only",
   "in": 66478,
   "out": 63076,
   "lost": 3402,
   "what": "Dropped rent listings hiding in sale data, zero/missing prices, corrupt values above Rs 100 Cr.",
   "why": "Price is the target \u2014 it can never be imputed. Guessed targets teach the model our guesses."
  },
  {
   "step": 3,
   "title": "Fix messy text",
   "in": 63076,
   "out": 63076,
