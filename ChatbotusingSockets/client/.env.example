# Leave VITE_API_URL empty (or commented out) to route API + WebSocket traffic
# through the Vite dev proxy. This is what makes the app work in GitHub
# Codespaces and any port-forward with no extra config. Only set it when the
# backend is hosted separately in production, e.g. https://api.example.com
# VITE_API_URL=

VITE_ENCRYPTION_SECRET=your-32-char-aes-key
